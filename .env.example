# OpenAI-compatible chat-completions endpoint.
# Defaults match the submitted EviMap artifact setup.
EVIMAP_LLM_BASE_URL=http://127.0.0.1:18021/v1
EVIMAP_LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
EVIMAP_LLM_API_KEY=local
EVIMAP_LLM_TIMEOUT_S=180

# Optional for vLLM / DeepSeek-style chat templates.
# Leave unset for OpenAI-hosted models.
EVIMAP_LLM_ENABLE_THINKING=false

# Round-2 leaf-topic dedup: within each finished mid-group, fold near-duplicate
# sibling topics (e.g. "Track Title" + "Track Titles") into one, gated by leaf
# title-embedding cosine >= EVIMAP_TOPIC_MERGE_SIM. On by default; set to 0 to disable.
EVIMAP_TOPIC_MERGE=1
EVIMAP_TOPIC_MERGE_SIM=0.82

# Sibling-aware naming: rewrite an over-broad catch-all heading that subsumes a
# more specific sibling (e.g. "Fruit" beside "Apples") into "Other X (excluding Y)".
# On by default; set to 0 to disable.
EVIMAP_CONTRASTIVE_NAMING=1

# Embeddings. The local default matches the paper.
EVIMAP_EMBEDDING_BACKEND=local
EVIMAP_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EVIMAP_EMBEDDING_DEVICE=auto
